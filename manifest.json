{
  "manifest_version": 3,
  "name": "AI Extension",
  "version": "1.0",
  "description": "Interview coding exercise",
  "permissions": ["scripting"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["contentScript.js"]
    }
  ]
}
